<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Clinica.Desktop.ViewModels"
             x:Class="Clinica.Desktop.Views.ExpedienteView"
             x:DataType="vm:ExpedienteViewModel">
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <TextBlock Text="Paciente:" VerticalAlignment="Center"/>
      <ComboBox Width="400" ItemsSource="{Binding Pacientes}" SelectedItem="{Binding PacienteSeleccionado}">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Etiqueta}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Content="Abrir documento" Command="{Binding AbrirDocumentoCommand}"/>
      <TextBlock Text="{Binding Mensaje}" VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.7"/>
    </StackPanel>

    <Grid ColumnDefinitions="*,*">
      <DockPanel Grid.Column="0" Margin="0,0,8,0">
        <TextBlock DockPanel.Dock="Top" Text="Historia clínica" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ListBox ItemsSource="{Binding Consultas}" SelectedItem="{Binding ConsultaSeleccionada}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,4">
                <TextBlock Text="{Binding Fecha}" FontWeight="Bold"/>
                <TextBlock Text="{Binding Motivo}" Opacity="0.9"/>
                <TextBlock Text="{Binding Diagnostico}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Medico}" FontSize="11" Opacity="0.6"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <DockPanel Grid.Column="1" Margin="8,0,0,0">
        <TextBlock DockPanel.Dock="Top" Text="Documentos médicos" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ListBox ItemsSource="{Binding Documentos}" SelectedItem="{Binding DocumentoSeleccionado}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,4">
                <TextBlock Text="{Binding Tipo}" FontWeight="Bold"/>
                <TextBlock Text="{Binding Fecha}" FontSize="11" Opacity="0.6"/>
                <TextBlock Text="{Binding Titulo}" TextWrapping="Wrap"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Grid>
  </DockPanel>
</UserControl>
