<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Clinica.Desktop.ViewModels"
             x:Class="Clinica.Desktop.Views.PagosView"
             x:DataType="vm:PagosViewModel">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Padding="12" Background="#f5f5f5" CornerRadius="8" Margin="0,0,0,12">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto,120,Auto,120,Auto">
          <TextBlock Grid.Column="0" Text="Concepto" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox Grid.Column="1" Text="{Binding Concepto}" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="2" Text="Monto Q" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox Grid.Column="3" Text="{Binding MontoTexto}" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="4" Text="Fecha" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox Grid.Column="5" Text="{Binding Fecha}" Margin="0,0,12,0"/>
          <Button Grid.Column="6" Content="Registrar" Command="{Binding RegistrarCommand}"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Método:" VerticalAlignment="Center"/>
          <TextBox Width="200" Text="{Binding MetodoPago}" Watermark="Efectivo, tarjeta…"/>
          <TextBlock Text="{Binding Mensaje}" VerticalAlignment="Center" Opacity="0.7"/>
        </StackPanel>
      </StackPanel>
    </Border>
    <ListBox Grid.Row="1" ItemsSource="{Binding Pagos}" SelectedItem="{Binding Seleccionado}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Padding="8,6" BorderBrush="#ddd" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="90,*,80,100,140">
              <TextBlock Grid.Column="0" Text="{Binding Fecha}"/>
              <TextBlock Grid.Column="1" Text="{Binding Concepto}" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="{Binding Monto, StringFormat={}{0:N2}}"/>
              <TextBlock Grid.Column="3" Text="{Binding Metodo}"/>
              <TextBlock Grid.Column="4" Text="{Binding Paciente}" Opacity="0.8"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
