<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Clinica.Desktop.ViewModels"
             x:Class="Clinica.Desktop.Views.CitasView"
             x:DataType="vm:CitasViewModel">
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <TextBlock Text="Fecha (yyyy-MM-dd):" VerticalAlignment="Center"/>
      <TextBox Width="140" Text="{Binding FiltroFecha}"/>
      <Button Content="Actualizar" Command="{Binding RefrescarCommand}"/>
      <TextBlock Text="{Binding Mensaje}" VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.7"/>
    </StackPanel>
    <ListBox ItemsSource="{Binding Citas}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Padding="8,6" BorderBrush="#ddd" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="140,*,140,*,90">
              <TextBlock Grid.Column="0" Text="{Binding FechaHora}"/>
              <TextBlock Grid.Column="1" Text="{Binding Paciente}" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="{Binding Medico}"/>
              <TextBlock Grid.Column="3" Text="{Binding Motivo}" Opacity="0.8"/>
              <TextBlock Grid.Column="4" Text="{Binding Estado}"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
